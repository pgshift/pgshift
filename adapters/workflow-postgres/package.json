{
  "name": "@pgshift/adapter-workflow-postgres",
  "description": "Internal PostgreSQL adapter for @pgshift/workflow.",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "homepage": "https://pgshift.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pgshift/pgshift.git"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "format": "biome format --write .",
    "lint": "biome lint ."
  },
  "dependencies": {
    "@pgshift/core": "*",
    "pg": "8.21.0"
  },
  "devDependencies": {
    "@pgshift/lint": "*",
    "@pgshift/ts": "*",
    "@types/pg": "8.20.0",
    "tsdown": "0.22.0"
  }
}
