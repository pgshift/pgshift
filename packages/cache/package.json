{
  "name": "@pgshift/cache",
  "version": "0.1.0",
  "description": "PgShift cache — materialized view caching powered by PostgreSQL.",
  "type": "module",
  "homepage": "https://pgshift-docs.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mkafonso/pgshift.git"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "format": "biome format --write .",
    "lint": "biome lint ."
  },
  "dependencies": {
    "@pgshift/adapter-cache-postgres": "*",
    "@pgshift/core": "*"
  },
  "devDependencies": {
    "@pgshift/lint": "*",
    "@pgshift/ts": "*",
    "tsdown": "0.22.0"
  }
}
